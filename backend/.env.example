PORT=3001
NODE_ENV=development

# Postgres (Supabase) - usa a Connection Pooling string do painel do projecto
# (Project Settings -> Database -> Connection Pooling -> URI, modo Session)
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-your-region.pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173
